# SAP credentials — used by project CLI wrappers
SAP_USERNAME=
SAP_PASSWORD=
SAP_CLIENT=800

# Quick BI credentials — LDAP/AD authentication
QBI_USERNAME=
QBI_PASSWORD=

# VPN (SealSuite/CorpLink) — optional, auto-detected from registry
# Only set if installed to a non-standard location
# SEALSUITE_EXE=C:\Program Files\CorpLink\current\Client\CorpLink.exe

# Lark (Feishu) bot credentials
# Create a bot at https://open.feishu.cn/app and enable:
#   - Messenger: Send messages (im:message:create_as_bot)
#   - Drive: Read files (drive:drive.file:readonly)
# Notification targets (chat/user per command) are in server/notify.toml
LARK_APP_ID=
LARK_APP_SECRET=

# PostgreSQL — see docker/ for setup
DATABASE_URL=postgresql://haidilao:haidilao_dev@localhost:5432/haidilao

# Admin OAuth — Lark-based login for /admin/* pages
# ADMIN_WHITELIST: comma-separated Lark open_ids allowed to access admin
# SESSION_SECRET: 32-byte hex string for signing session cookies (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
ADMIN_WHITELIST=
SESSION_SECRET=
# Override the OAuth redirect URI for local dev (default: production URL)
LARK_OAUTH_REDIRECT_URI=https://haidilao.wanghongming.xyz/admin/oauth/callback

# Treasury loan maturity watch
TREASURY_NOTIFY_CHAT_ID=           # Lark group chat open_chat_id for maturity alerts
# TREASURY_SHEET_TOKEN=T8NosM6aRhj8v0t6JA8cugS9nYb  # override if sheet moves
# TREASURY_SHEET_ID=16yYcs                            # override if tab changes

# Store working-hour data collection
HOURS_NOTIFY_CHAT_ID=              # Lark group for unfilled data alerts
# HOURS_TEMPLATE_TOKEN=SbTns7kTxhxn5TtLMyccOrqRnqe  # template spreadsheet
# HOURS_FOLDER_TOKEN=AVt8fGZLHl5PzJd2gw3cNa10ntd    # target folder

# GitHub webhook receiver (POST /api/github/webhook)
# Set the same secret here as in the GitHub repo webhook settings
# If unset, signature verification is skipped (not recommended for production)
GITHUB_WEBHOOK_SECRET=

# MinIO local file storage (for admin Tools page at /admin/tools)
# MinIO runs via docker-compose on ports 9000 (API) and 9001 (console)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=haidilao
MINIO_ROOT_PASSWORD=haidilao_minio_dev
MINIO_BUCKET=tools-uploads
MINIO_SECURE=false

# Super-admin open_ids (comma-separated Lark open_ids) — these users can access /admin/tools
SUPER_ADMIN_OPEN_IDS=
