  Model: sonnet
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.haidilao.claude.log-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/Users/hongming-claw/.local/bin/claude --print --dangerously-skip-permissions --model sonnet --add-dir /Users/hongming-claw/haidilao-business-intelligent --add-dir /Users/hongming-claw/haidilao-automation-monorepo -p "$(cat '/Users/hongming-claw/haidilao-business-intelligent/prompts/log-monitor.md')"</string>
