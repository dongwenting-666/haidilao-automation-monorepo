    <key>StandardOutPath</key>
    <string>/Users/hongming-claw/haidilao-business-intelligent/data/cron-logs/health-check.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/hongming-claw/haidilao-business-intelligent/data/cron-logs/health-check.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/hongming-claw</string>
        <key>PATH</key>
        <string>/Users/hongming-claw/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>TimeOut</key>
    <integer>300</integer>
</dict>
</plist>